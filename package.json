{
  "name": "streamweave",
  "version": "0.2.0",
  "description": "StreamWeaver - local-only Node automation server with a browser control UI",
  "author": "StreamWeaver Team",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cross-env WS_PORT=8090 npx dotenv-cli -e .env -- tsx server.ts",
    "dev:dashboard": "cross-env DASHBOARD_MODE=true concurrently \"npm:dev:next\" \"npm:dev:ws\"",
    "dev:next": "cross-env PORT=3100 NEXT_PUBLIC_STREAMWEAVE_PORT=3100 npx next dev -p 3100 -H 127.0.0.1",
    "dev:ws": "cross-env WS_PORT=8090 npx tsx server.ts",
    "build": "npm run lint && npm run typecheck && npx next build",
    "build:simple": "npx next build",
    "start": "cross-env NODE_ENV=production npx dotenv-cli -e .env -- tsx scripts/start-local.ts",
    "lint": "npx next lint",
    "typecheck": "tsc --noEmit",
    "health-check": "node health-check.js",
    "setup": "npm run health-check",
    "postinstall": "node scripts/bootstrap-runtime.js",
    "streamweaver:simple": "cross-env WS_PORT=8090 npx tsx server.ts",
    "start:local": "cross-env NODE_ENV=production WS_PORT=8090 PORT=3100 NEXT_PUBLIC_STREAMWEAVE_PORT=3100 npx dotenv-cli -e .env -- tsx scripts/start-local.ts",
    "package:release": "npx tsx scripts/package-local-release.ts source",
    "package:win": "npm run build:simple && npx pkg . --targets node20-win-x64 --output dist/bin/StreamWeaver.exe && npx tsx scripts/package-local-release.ts win",
    "package:mac": "npm run build:simple && npx pkg . --targets node20-macos-x64 --output dist/bin/StreamWeaver && npx tsx scripts/package-local-release.ts mac",
    "package:linux": "npm run build:simple && npx pkg . --targets node20-linux-x64 --output dist/bin/StreamWeaver && npx tsx scripts/package-local-release.ts linux"
  },
  "dependencies": {
    "@emnapi/runtime": "^1.7.0",
    "@google-cloud/speech": "^6.5.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^4.1.3",
    "@next-auth/firebase-adapter": "^2.0.1",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@types/pako": "^2.0.4",
    "@types/wav": "^1.0.4",
    "ansi_up": "^6.0.0",
    "axios": "^1.7.2",
    "buffer": "^6.0.3",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cowsay": "^1.6.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "embla-carousel-react": "^8.6.0",
    "figlet": "^1.10.0",
    "firebase": "^11.9.1",
    "firebase-admin": "^12.7.0",
    "form-data": "^4.0.0",
    "framer-motion": "^11.5.7",
    "googleapis": "^168.0.0",
    "lottie-react": "^2.4.0",
    "lucide-react": "^0.475.0",
    "next": "^15.3.3",
    "next-auth": "^4.24.13",
    "obs-websocket-js": "^5.0.7",
    "pako": "^2.1.0",
    "process": "^0.11.10",
    "pusher-js": "^8.4.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "tiktok-live-connector": "^2.1.1-beta1",
    "tmi.js": "^1.8.5",
    "utf-8-validate": "^6.0.6",
    "wav": "^1.0.2",
    "ws": "^8.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@types/aws-lambda": "^8.10.159",
    "@types/node": "^20.19.29",
    "@types/react": "18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/tmi.js": "^1.8.6",
    "@types/ws": "^8.5.10",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "15.3.3",
    "patch-package": "^8.0.0",
    "pkg": "^5.8.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.11.0",
    "typescript": "5.9.3"
  },
  "pkg": {
    "scripts": [
      "server.ts",
      "scripts/start-local.ts",
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "assets": [
      "public/**/*",
      ".next/**/*",
      "config/**/*",
      "data/**/*",
      "tokens/**/*",
      "README-LOCAL-APP.md"
    ],
    "outputPath": "dist"
  }
}
