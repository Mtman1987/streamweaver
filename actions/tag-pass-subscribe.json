{
  "id": "tag-pass-subscribe",
  "name": "Earn Tag Pass - Subscribe",
  "description": "Awards a tag pass when someone subscribes",
  "triggers": [
    {
      "type": 103,
      "config": {
        "tier1": true,
        "tier2": true,
        "tier3": true,
        "prime": true
      }
    }
  ],
  "subActions": [
    {
      "id": "get-current-tag-passes",
      "type": 1051,
      "enabled": true,
      "weight": 1,
      "index": 0,
      "userName": "%user%",
      "variableName": "tagPasses",
      "defaultValue": "0",
      "destinationVariable": "currentTagPasses"
    },
    {
      "id": "increment-tag-passes",
      "type": 1052,
      "enabled": true,
      "weight": 2,
      "index": 1,
      "operand1": "%currentTagPasses%",
      "operation": "add",
      "operand2": "1",
      "variableName": "newTagPasses"
    },
    {
      "id": "set-new-tag-passes",
      "type": 1050,
      "enabled": true,
      "weight": 3,
      "index": 2,
      "userName": "%user%",
      "variableName": "tagPasses",
      "value": "%newTagPasses%",
      "persisted": true
    },
    {
      "id": "send-earn-message",
      "type": 10,
      "enabled": true,
      "weight": 4,
      "index": 3,
      "message": "Thanks %user% for subscribing to the streamer! You earned a 'free tag' pass! Use !tag @username to tag someone in chat. You now have %newTagPasses% tag passes.",
      "useBot": true
    }
  ],
  "enabled": true,
  "concurrent": false,
  "queue": false,
  "group": "Tag Game",
  "createdAt": "2025-01-27T00:00:00.000Z",
  "updatedAt": "2025-01-27T00:00:00.000Z"
}